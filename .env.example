# ============================================================================
# Farahi Law — BD Partner CRM — Environment Template
# ----------------------------------------------------------------------------
# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
#
# IMPORTANT: variables that start with VITE_ are baked into the CLIENT bundle
# at BUILD time (`pnpm build`). They must be present BEFORE you build, not just
# at runtime. The non-VITE vars are read by the server at runtime.
# ============================================================================

# --- Core / required -------------------------------------------------------
# MySQL/TiDB connection string. This is the LIVE production database.
DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/DBNAME?ssl={\"rejectUnauthorized\":true}"

# Secret used to sign the login session cookie (JWT). REQUIRED in production.
# Generate a strong one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# App identifier (also embedded in the client). Any stable string is fine.
VITE_APP_ID="farahi-crm"

# The super-admin's openId — used to seed the first login and the dev backdoor.
OWNER_OPEN_ID="dKPzy5chgLYyGR7PJmYjEj"

# Server port (optional, default 3000). Put your reverse proxy in front of this.
PORT="3000"

# --- Authentication mode ---------------------------------------------------
# Per-user password login is always on (the Login screen). Leave the Manus
# OAuth vars UNSET — that keeps the app in self-hosted/password mode.
# OAUTH_SERVER_URL=
# VITE_OAUTH_PORTAL_URL=
#
# DEV-ONLY BACKDOOR: when "true", GET /api/local-login signs you in as the owner
# with NO password. NEVER set this in production — anyone who finds the URL
# becomes the super admin. Leave it unset/false on the server.
ALLOW_LOCAL_LOGIN="false"

# --- AI: transcription + call summaries (OpenAI-compatible) ----------------
# Repointed off Manus Forge to OpenAI. Used for Whisper transcription and the
# call-summary / auto-task LLM.
BUILT_IN_FORGE_API_URL="https://api.openai.com"
BUILT_IN_FORGE_API_KEY="sk-..."
LLM_MODEL="gpt-4o-mini"

# --- Google Maps -----------------------------------------------------------
# Same key works for both. VITE_ one is baked into the client at build time.
GOOGLE_MAPS_API_KEY="AIza..."
VITE_GOOGLE_MAPS_API_KEY="AIza..."

# --- RingCentral (direct facility calling + call-log sync) -----------------
RINGCENTRAL_CLIENT_ID="..."
RINGCENTRAL_CLIENT_SECRET="..."
# JWT credential used for the jwt-bearer grant (server mints access tokens).
RINGCENTRAL_JWT="eyJ..."

# --- Optional --------------------------------------------------------------
# Only if you use client-side Forge AI features (maps/autocomplete helpers).
# VITE_FRONTEND_FORGE_API_KEY=
